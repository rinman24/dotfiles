{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Keeps the canon marketplace pin in claude/settings-fragment.json current with canon's git tags.",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^claude/settings-fragment\\.json$/"],
      "matchStrings": [
        "\"repo\":\\s*\"rinman24/canon\",\\s*\"ref\":\\s*\"(?<currentValue>v\\d+\\.\\d+\\.\\d+)\""
      ],
      "depNameTemplate": "rinman24/canon",
      "datasourceTemplate": "github-tags"
    }
  ]
}
